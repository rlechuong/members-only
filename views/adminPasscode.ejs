<%- include("partials/header.ejs") %>

<h1 class="form-heading">Admin Passcode</h1>

<% if (error) { %>
  <p class="form-error"><%= error %></p>
<% } %>

<form action="/admin-passcode" method="POST" class="admin-passcode-form">
	<div class="form-group">
		<label for="passcode">Passcode</label>
		<input id="passcode" name="passcode" type="password" required />
	</div>

	<button type="submit">Verify</button>
</form>

<a href="/" class="cancel-link">Cancel</a>

<p class="demo-note">For demo purposes, the passcode is: <strong><%= process.env.ADMIN_PASSCODE %></strong></p>

<%- include("partials/footer.ejs") %>